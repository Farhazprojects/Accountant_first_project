# =============================================================
# Accountant First — Environment Variables (copy to .env)
# =============================================================
# IMPORTANT: Never commit the actual .env file. Use strong, randomly
# generated values for JWT_SECRET and DB_PASSWORD in production.
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ---- Database ------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=accountant_first_dev
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---- JWT Authentication -------------------------------------
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ---- CORS ---------------------------------------------------
# Comma-separated list of allowed frontend origins
# Example: https://app.accountantfirst.com,https://www.accountantfirst.com
CORS_ORIGIN=http://localhost:3000

# ---- Application Port (Docker internal) ---------------------
PORT=5000

# ---- Stripe (Billing) ---------------------------------------
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ---- SendGrid (Email) ---------------------------------------
SENDGRID_API_KEY=SG.REPLACE_ME

# ---- AWS S3 (Document Storage) ------------------------------
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_S3_BUCKET_NAME=REPLACE_ME
AWS_REGION=ap-southeast-2

# ---- Frontend Build (Docker build-time arg) -----------------
REACT_APP_API_URL=/api
