# =============================================================
# Accountant First — Backend Environment Variables (copy to .env)
# =============================================================
# For LOCAL development only (outside Docker).
# Docker Compose uses the root .env file via env_file.

# ---- Database (local dev points to localhost) ---------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accountant_first_dev
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---- JWT Authentication -------------------------------------
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ---- CORS (local dev) ---------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---- Application Port ---------------------------------------
PORT=5000

# ---- AWS S3 (use mock values for local dev) -----------------
AWS_ACCESS_KEY_ID=mock_aws_key
AWS_SECRET_ACCESS_KEY=mock_aws_secret
AWS_S3_BUCKET_NAME=mock_bucket
AWS_REGION=ap-southeast-2
