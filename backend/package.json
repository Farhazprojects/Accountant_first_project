    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.1",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "puppeteer": "^20.9.0",
    "sequelize": "^6.32.1",
    "stripe": "^12.12.0",
    "xero-node": "^18.0.0"
